# Copy to .env and fill in values before running any reference agent.
# .env is gitignored — never commit real secrets.

# --- Required ---

# Anthropic API key for Claude model calls.
ANTHROPIC_API_KEY=

# Slack bot token (xoxb-...) for posting agent output to channels.
SLACK_BOT_TOKEN=

# Default Slack channel ID for agent output (e.g. C0XXXXXXX).
SLACK_DEFAULT_CHANNEL=

# --- Optional data sources referenced in example agents ---

# CRYPTOCOMPARE_API_KEY=
# LUNARCRUSH_API_KEY=
# BLOCKSCOUT_API_KEY=
